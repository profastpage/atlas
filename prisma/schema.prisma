generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========================================
// MULTI-TENANT CORE
// ========================================

model Tenant {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  sessions   Session[]
  userMemory UserMemory?
}

model Session {
  id        String   @id @default(cuid())
  tenantId  String
  title     String   @default("Sesión Atlas")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // "user" | "assistant" | "system"
  content   String
  timestamp DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ========================================
// SUPABASE-STYLE USER MEMORY MODULE
// Mirror of: user_memory table (user_id, user_name, context_summary)
// ========================================

model UserMemory {
  id             String   @id @default(cuid())
  tenantId       String   @unique  // acts as user_id in Supabase
  userName       String   @default("")       // user_name field
  contextSummary String   @default("")       // context_summary field (1-line summaries only)
  lastTopic      String   @default("")       // último tema tratado para referencia rápida
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
